---
const { items = [] } = Astro.props;
---
{items?.length > 0 && (
  <div class="grid grid-3">
    {items.map((item, index) => (
      <div class="card reveal" style={`--delay: ${index * 80}ms;`}>
        <h3 class="card-title">{item.title}</h3>
        <p class="muted">{item.description}</p>
      </div>
    ))}
  </div>
)}
