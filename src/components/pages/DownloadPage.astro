---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSite, withLocalePath } from '../../data/site';
import SectionHeading from '../SectionHeading.astro';
import CTA from '../CTA.astro';

const { locale = 'es' } = Astro.props;
const site = getSite(locale);
const meta = site.meta?.pages?.download;
const isSpanish = locale === 'es';
---
<BaseLayout
  locale={locale}
  pageTitle={meta?.title}
  pageDescription={meta?.description}
  breadcrumbs={[{ label: 'Descargas' }]}
>
  {isSpanish && (
    <>
      <section class="section">
        <div class="container">
          <SectionHeading
            eyebrow="Acceso"
            title={site.download?.title}
            title={site.download?.title}
            subtitle={site.download?.subtitle}
          />

          {site.download?.appStores && (
            <div style="display: flex; justify-content: center; gap: 16px; margin-bottom: 48px; flex-wrap: wrap;">
               <a href={site.download.appStores.ios} target="_blank" class="store-badge apple">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.65 19.39c-1.35 1.94-2.8 3.98-5.3 4.02-2.3.04-3.05-1.39-5.71-1.39-2.66 0-3.5 1.35-5.69 1.4-2.28.05-4.04-2.31-5.5-4.43C-6.53 16.14-1.78 6.42 4.19 6.13c2.7-.13 4.67 1.83 6.13 1.83 1.46 0 4.2-2.25 7.1-1.91 1.23.05 4.7.49 6.92 3.76-6.09 3.02-5.11 9.94 1.22 12.55-.95 2.5-2.29 4.95-3.91 7.03zM12.98 3.89c1.23-1.48 2.05-3.55 1.83-5.6-1.78.07-3.92 1.18-5.18 2.65-1.12 1.3-2.11 3.42-1.84 5.37 1.98.15 4-.9 5.19-2.42z"/></svg>
                  <span>Descargar en <strong>App Store</strong></span>
               </a>
               <a href={site.download.appStores.android} target="_blank" class="store-badge google">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M3 20.5v-17c0-.83.67-1.5 1.5-1.5h13a1.5 1.5 0 0 1 1.5 1.5v7l-5.65 5.65c-.2.2-.51.2-.71 0L3 7.41V20.5zM17 12l-4.5 4.5 4.5 4.5V12zM5.5 22h13c.83 0 1.5-.67 1.5-1.5v-2.09l-5.5-5.5L4 22h1.5z"/></svg>
                  <span>Disponible en <strong>Google Play</strong></span>
               </a>
            </div>
          )}

          <style>
              .store-badge {
                  display: inline-flex;
                  align-items: center;
                  gap: 12px;
                  background: #000;
                  color: #fff;
                  padding: 12px 24px;
                  border-radius: 12px;
                  text-decoration: none;
                  transition: transform 0.2s, box-shadow 0.2s;
              }
              .store-badge:hover {
                  transform: translateY(-2px);
                  box-shadow: 0 10px 20px rgba(0,0,0,0.2);
              }
              .store-badge.google {
                  background: #fff;
                  color: #000;
                  border: 1px solid #e2e8f0;
              }
          </style>

          <div class="grid grid-3">
            {site.download?.options?.map((option, index) => (
              <div class="card reveal" style={`--delay: ${index * 80}ms;`}>
                <h3 class="card-title">{option.title}</h3>
                <p class="muted">{option.description}</p>
                {option.cta?.label && (
                  <a class="btn btn-primary" href={withLocalePath(locale, option.cta.href)}>
                    {option.cta.label}
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      <CTA
        locale={locale}
        title="¿Quieres priorizar tu acceso?"
        subtitle="Indícanos tu contexto y te ofrecemos la mejor opción."
        primaryCta={{ label: 'Contactar', href: '/contacto' }}
        secondaryCta={{ label: 'Ver cómo funciona', href: '/como-funciona' }}
      />
    </>
  )}
</BaseLayout>
