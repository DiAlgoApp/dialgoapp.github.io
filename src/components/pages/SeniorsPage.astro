---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSite } from '../../data/site';
import SectionHeading from '../SectionHeading.astro';
import ListStack from '../ListStack.astro';
import CTA from '../CTA.astro';

const { locale = 'es' } = Astro.props;
const site = getSite(locale);
const meta = site.meta?.pages?.seniors;
const isSpanish = locale === 'es';
---
<BaseLayout
  locale={locale}
  pageTitle={meta?.title}
  pageDescription={meta?.description}
  breadcrumbs={[
    { label: 'Para quién', href: '/para-cuidadores' },
    { label: 'Personas mayores' },
  ]}
>
  {isSpanish && (
    <>
      <section class="section">
        <div class="container">
          <SectionHeading
            eyebrow="Personas mayores"
            title={site.seniors?.title}
            subtitle={site.seniors?.subtitle}
          />
          <div class="grid grid-2">
            <div class="card">
              <h3 class="card-title">Interfaz simplificada</h3>
              <ListStack items={site.seniors?.features} />
            </div>
            <div class="card card--glass">
              <h3 class="card-title">Acompañamiento y ajustes</h3>
              <p class="muted">{site.seniors?.support?.description}</p>
              <div class="tag-list" style="margin-top: 18px;">
                <span class="tag">Lectura fácil</span>
                <span class="tag">Botones grandes</span>
                <span class="tag">Alertas claras</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section section--soft">
        <div class="container">
          <SectionHeading
            eyebrow="Accesibilidad"
            title="Diseño conforme a WCAG AA"
            subtitle="Contraste adecuado, tipografía escalable y navegación por teclado."
          />
          <div class="grid grid-3">
            <div class="card">
              <h3 class="card-title">Tipografía legible</h3>
              <p class="muted">Escalas responsivas y tamaños mínimos de lectura cómoda.</p>
            </div>
            <div class="card">
              <h3 class="card-title">Objetivos táctiles</h3>
              <p class="muted">Botones de al menos 44px para evitar errores.</p>
            </div>
            <div class="card">
              <h3 class="card-title">Navegación guiada</h3>
              <p class="muted">Flujos lineales que reducen confusiones.</p>
            </div>
          </div>
        </div>
      </section>

      <CTA
        locale={locale}
        title="Cuidar también es comunicar"
        subtitle="Ofrece a tus mayores una experiencia calmada y segura."
        primaryCta={{ label: 'Probar ahora', href: '/contacto' }}
        secondaryCta={{ label: 'Ver cómo funciona', href: '/como-funciona' }}
      />
    </>
  )}
</BaseLayout>
