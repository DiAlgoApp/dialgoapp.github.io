---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale, getSite, locales, swapLocalePath } from '../data/site';

const { locale = defaultLocale, pageTitle, pageDescription, path } = Astro.props;
const site = getSite(locale);
const title = pageTitle
  ? pageTitle.includes(site.siteName)
    ? pageTitle
    : `${pageTitle} — ${site.siteName}`
  : site.meta?.defaultTitle || site.siteName;
const description = pageDescription || site.meta?.defaultDescription || '';
const keywords = site.meta?.keywords;
const currentPath = path || Astro.url.pathname || '/';
const canonical = site.siteUrl ? new URL(currentPath, site.siteUrl).toString() : currentPath;
const ogImage = site.siteUrl ? new URL('/og-image.png', site.siteUrl).toString() : '/og-image.png';
const langLinks = locales.map((code) => ({
  code,
  label: code.toUpperCase(),
  href: swapLocalePath(currentPath, code),
  active: code === locale,
}));
const alternateLinks = langLinks.map((link) => ({
  ...link,
  absolute: site.siteUrl ? new URL(link.href, site.siteUrl).toString() : link.href,
}));
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.siteName,
  operatingSystem: 'iOS, Android',
  applicationCategory: 'MedicalApplication',
  url: site.siteUrl,
  description,
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="theme-color" content="#0f766e" />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.code} href={link.absolute} />
    ))}
    <link rel="icon" href="/logo.png" type="image/png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json">{JSON.stringify(jsonLd)}</script>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Nav locale={locale} navItems={site.nav} ctas={site.headerCta} langLinks={langLinks} />
    <main id="contenido">
      <slot />
    </main>
    <Footer locale={locale} footer={site.footer} />
  </body>
</html>
